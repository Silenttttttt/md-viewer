{
  "name": "md-viewer",
  "version": "1.0.0",
  "description": "Fast markdown viewer and editor with tabs, Mermaid, and live reload",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "build:watch": "tsc -p tsconfig.main.json -w & tsc -p tsconfig.renderer.json -w",
    "start": "npm run build && electron .",
    "test": "jest",
    "pretest": "npm run build",
    "test:unit": "jest test/unit",
    "test:dom": "jest test/dom",
    "test:e2e": "playwright test",
    "test:all": "jest && playwright test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "electron": "^42.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  }
}
